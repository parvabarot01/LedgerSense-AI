# Copy to .env.local and fill in with your own free-tier credentials.
# Nothing in this repo talks to any of these services until you do.

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis (rate limiting) - Upstash console -> Redis database -> REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash QStash (async detection jobs) - Upstash console -> QStash
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Public base URL of this app (used to build the QStash callback URL).
# For local dev with QStash you need a tunnel (e.g. ngrok); detection runs
# fall back to a synchronous in-process run when this or the QStash vars
# are unset, so local dev works without a tunnel.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Groq (AI explanation copilot + natural-language query) - console.groq.com
GROQ_API_KEY=
